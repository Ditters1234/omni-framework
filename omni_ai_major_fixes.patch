diff --git a/systems/ai/providers/openai_provider.gd b/systems/ai/providers/openai_provider.gd
index b015d7f..0000000 100644
--- a/systems/ai/providers/openai_provider.gd
+++ b/systems/ai/providers/openai_provider.gd
@@ -137,17 +137,20 @@ func _build_headers() -> PackedStringArray:
