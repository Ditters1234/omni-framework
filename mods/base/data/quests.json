      "display_name": "Deliver Package",
      "description": "Deliver a sealed package to a dead drop near your apartment. Don't open it.",
      "stages": [
        {
          "description": "Carry the package to the apartment dead drop.",
          "objectives": [
            { "type": "reach_location", "entity_id": "quest:assignee", "location_id": "base:apartment" }
          ]
        }
      ],
      "reward": {
        "credits": 75,
        "reputation": { "base:threshold_syndicate": 10 }
      },
      "complete_sound": "res://mods/base/assets/audio/sfx_task_complete.wav",
      "repeatable": true
    },
    {
      "quest_id": "base:supply_run",
