{
  "game": {
    "title": "Neon Threshold",
    "tagline": "Scrap it. Rebuild. Survive.",
    "starting_location": "base:apartment",
    "ticks_per_day": 24,
    "ticks_per_hour": 1,
    "starting_discovered_locations": [
      "base:apartment",
      "base:market_row"
    ],
    "starting_player_id": "base:player",
    "new_game_flow": {
      "screen_id": "gameplay_shell",
      "params": {
        "initial_surface_id": "assembly_editor",
        "disable_shell_chrome": true,
        "initial_surface_params": {
          "screen_title": "Body Configuration",
          "screen_description": "Assemble your starting body. Choose a head, torso, and limbs from biological or synthetic stock, then install any implants you can afford.",
          "screen_summary": "Preview a part on the left, inspect its stats on the right, then apply it. Unspent credits carry into the game.",
          "target_entity_id": "player",
          "budget_currency_id": "credits",
          "option_tags": [
            "head",
            "torso",
            "arms",
            "legs",
            "hands",
            "feet",
            "neural_implant",
            "subdermal_armor",
            "weapon"
          ],
          "confirm_label": "Enter Neon Threshold",
          "cancel_label": "Back",
          "pop_on_confirm": true,
          "cancel_screen_id": "main_menu",
          "reset_game_state_on_cancel": true,
          "allow_confirm_without_changes": true
        }
      }
    }
  },
  "economy": {
    "default_currency_id": "credits"
  },
  "tasks": {
    "default_assignment_task_template_id": "base:goto_location",
    "default_travel_task_template_id": "base:goto_location"
  },
  "crafting": {
    "default_task_template_id": "base:recipe_craft"
  },
  "ui": {
    "main_menu": {
      "title": "Neon Threshold",
      "subtitle": "Build yourself. Break the system.",
      "new_game_label": "New Body",
      "continue_label": "Resume Session",
      "load_label": "Load Save",
      "settings_label": "Settings",
      "credits_label": "Credits",
      "quit_label": "Exit"
    },
    "time_advance_buttons": [
      "1 hour",
      {
        "label": "Rest",
        "ticks": 4,
        "task_template_id": "base:downtime",
        "entity_id": "player",
        "allow_duplicate": true,
        "status_text": "Rested and recovered."
      },
      "1 day"
    ],
    "strings": {
      "boot_status": "Neon Threshold ready."
    },
    "theme": {
      "primary_color": "#00d4aa",
      "secondary_color": "#ff6b9d",
      "bg_color": "#0a0e17",
      "text_color": "#e8ecf4",
      "text_muted": "#6b7a94",
      "color_positive": "#4ade80",
      "color_negative": "#f87171",
      "color_warning": "#fbbf24",
      "color_info": "#60a5fa"
    },
    "stat_group_color_tokens": {
      "combat": "warning",
      "survival": "positive",
      "economy": "primary"
    },
    "default_sprites": {
      "parts": {
        "head": "res://mods/base/assets/images/fallbacks/generic_head.png",
        "hair": "res://mods/base/assets/images/fallbacks/generic_hat.png",
        "torso": "res://mods/base/assets/images/fallbacks/generic_torso.png",
        "body_core": "res://mods/base/assets/images/fallbacks/generic_torso.png",
        "arm": "res://mods/base/assets/images/fallbacks/generic_arm.png",
        "wing": "res://mods/base/assets/images/fallbacks/generic_arm.png",
        "leg": "res://mods/base/assets/images/fallbacks/generic_leg.png",
        "tail": "res://mods/base/assets/images/fallbacks/generic_leg.png",
        "hand": "res://mods/base/assets/images/fallbacks/generic_hand.png",
        "foot": "res://mods/base/assets/images/fallbacks/generic_foot.png",
        "nose_cone": "res://mods/base/assets/images/fallbacks/generic_cyberware.png",
        "fin": "res://mods/base/assets/images/fallbacks/generic_cyberware.png",
        "thruster": "res://mods/base/assets/images/fallbacks/generic_cyberware.png",
        "vehicle_core": "res://mods/base/assets/images/fallbacks/generic_cyberware.png",
        "rocket_core": "res://mods/base/assets/images/fallbacks/generic_cyberware.png"
