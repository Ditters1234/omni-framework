  "stats": {
    "groups": {
      "combat": [
        "power",
        "armor"
      ],
      "social": [
        "charisma",
        "luck"
      ],
      "survival": [
        "health",
        "health_max",
        "stamina",
        "stamina_max"
      ]
    }
  },
  "entity_lifecycle": {
    "rules": [
      {
        "rule_id": "base:zero_health_incapacitated",
        "display_name": "Incapacitated",
        "stat": "health",
        "state_flag": "base:incapacitated",
        "condition": {
          "type": "stat_check",
          "entity_id": "context:entity",
          "stat": "health",
          "op": "<=",
          "value": 0
        },
        "notification": "{entity_name} is incapacitated.",
        "notification_level": "warning",
        "clear_when_condition_false": true,
        "exit_notification": "{entity_name} is no longer incapacitated.",
        "exit_notification_level": "info",
        "game_over_on_player": true
      }
    ]
  },
  "ai": {
    "narration_enabled": true,
    "task_flavor_enabled": true,
    "activity_flavor_enabled": true,
    "lore_enabled": true,
    "encounter_log_flavor_enabled": true,
    "encounter_log_template_id": "base:encounter_log_flavor",
    "world_gen_hooks": {
      "narration": "res://mods/base/scripts/ai_narration_hook.gd",
      "task_flavor": "res://mods/base/scripts/ai_task_flavor_hook.gd",
      "activity_flavor": "res://mods/base/scripts/ai_activity_flavor_hook.gd",
      "lore": "res://mods/base/scripts/ai_lore_hook.gd"
    }
  }
